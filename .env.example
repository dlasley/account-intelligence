# Copy to .env and fill in real values. Never commit .env.

# --- LLM providers ---
ANTHROPIC_API_KEY=       # narrative generation (Claude Opus 4.7)
OPENAI_API_KEY=          # embeddings (text-embedding-3-small, Phase 6)

# --- Supabase (Python worker + MCP) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=   # MCP server only (not used by worker at runtime)
SUPABASE_PROJECT_REF=    # MCP server only — substituted into .mcp.json URLs. Must be exported in process env (~/.zshenv on macOS so the VS Code GUI inherits it), not just .env.

# --- Supabase (Next.js frontend — same project, different key prefix) ---
# NEXT_PUBLIC_ prefix is required for Next.js to expose values to the client bundle.
NEXT_PUBLIC_SUPABASE_URL=        # same value as SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # same value as SUPABASE_ANON_KEY
NEXT_PUBLIC_WORKER_URL=          # Cloud Run service URL, e.g. https://csp-worker-xxxxx.us-central1.run.app (leave empty for local dev when running worker on :8080 with a proxy)

# --- Inbound email ---
INBOUND_DOMAIN=signal.example.com   # e.g. signal.yourdomain.com — public placeholder; production value set in deploy env

# --- HTTP server ---
WEBHOOK_SECRET=        # Required for /inbound — set to a random 32-char string; passed as ?token=<VALUE> query param (SendGrid Inbound Parse doesn't support custom headers)
SCHEDULER_SECRET=      # Required for /run-narratives — set to a random 32-char string; passed as Authorization: Bearer header by Cloud Scheduler
INTEGRATION_ENCRYPTION_KEY=   # Required for ADR-020 integration credentials. 32-byte random value, base64-encoded. Generate: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
SENDGRID_API_KEY=      # Required for /outreach/send — SendGrid Transactional API key
CORS_ORIGINS=          # Comma-separated allowed origins, e.g. http://localhost:3000 (local) or https://your-app.vercel.app (prod). Unset = no CORS headers.
FASTAPI_DEBUG=         # Set to "true" to enable /docs UI locally
LOG_LEVEL=             # Defaults to WARNING; set to INFO for Cloud Run

# --- PostHog analytics + LLM observability (worker) ---
# Both product analytics (src/analytics.py) and LLM observability (src/observability/llm.py)
# use the same API key + host.  See docs/architecture.md for the boundary between them.
POSTHOG_API_KEY=           # PostHog project API key (same value as NEXT_PUBLIC_POSTHOG_KEY)
POSTHOG_HOST=              # e.g. https://us.i.posthog.com
POSTHOG_ENABLED=false      # product analytics on/off; true in prod, false locally
POSTHOG_LLM_OBSERVABILITY_ENABLED=true  # LLM OTel instrumentation; on by default when POSTHOG_API_KEY is set
DEPLOY_ENV=development     # injected into OTel resource attributes; set to "production" in prod
APP_ENV=                   # product analytics distinct_id prefix; set to "production" in prod

# --- PostHog analytics (Next.js frontend) ---
NEXT_PUBLIC_POSTHOG_KEY=         # PostHog project API key
NEXT_PUBLIC_POSTHOG_HOST=        # e.g. https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_ENABLED=false  # true in prod; false locally

# --- Pinecone (Phase 6 — Draft Outreach RAG) ---
# PINECONE_API_KEY=
# PINECONE_INDEX=
